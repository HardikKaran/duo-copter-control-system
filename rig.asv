function params = rig()
    params.g = 9.81;

    m_cart = 0.15; % [kg] cart
    m_motor = 0.114; % [kg] each (motor 28-35)
    m_esc = 0.040; % [kg] each
    m_propeller = 0.010; % [kg] each
    m_structure = 0.0565; % [kg] CAD design 
    params.m_fixed = m_cart + 2*(m_motor + m_esc + m_propeller + m_structure);


end